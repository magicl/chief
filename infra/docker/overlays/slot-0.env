# Slot 0 (default). DOCO_PORT is nginx; DOCO_PORT_BACKEND is direct backend access.
DOCO_SUFFIX=
DOCO_PORT=80
DOCO_PORT_BACKEND=8000
DOCO_PORT_POSTGRES=5432
DOCO_PORT_REDIS=6379

DOCO_NETWORK=chief-network
DOCO_PG_VOLUME=chief_postgres_data
DOCO_STATIC_VOLUME=chief_static_data

DOCO_SITE_DOMAIN=localhost
DOCO_EMAIL_DIR=.output/emails

# Required by the olib compose template (unused by chief yet).
DOCO_PORT_NODEJS=3000
DOCO_PORT_OAUTH_MOCK=8125
