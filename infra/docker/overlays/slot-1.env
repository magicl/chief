# Slot 1. DOCO_PORT is nginx; DOCO_PORT_BACKEND is direct backend access.
DOCO_SUFFIX=_1
DOCO_PORT=8081
DOCO_PORT_BACKEND=8100
DOCO_PORT_POSTGRES=5532
DOCO_PORT_REDIS=6479

DOCO_NETWORK=chief-network-s1
DOCO_PG_VOLUME=chief_postgres_data_s1
DOCO_STATIC_VOLUME=chief_static_data_s1

DOCO_SITE_DOMAIN=localhost:8081
DOCO_EMAIL_DIR=.output/emails-s1

# Required by the olib compose template (unused by chief yet).
DOCO_PORT_NODEJS=3100
DOCO_PORT_OAUTH_MOCK=8225
