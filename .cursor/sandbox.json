{
  "type": "workspace_readwrite",
  "terminalAllowlist": [
    "./olib/scripts/orunr",
    "./olib/scripts/orunr*"
  ],
  "additionalReadonlyPaths": [
    "/mnt/infra-assets/chief"
  ],
  "enableSharedBuildCache": true,
  "networkPolicy": {
    "default": "deny",
    "allow": [
      "localhost",
      "127.0.0.0/8",
      "::1",
      "registry.npmjs.org",
      "registry.yarnpkg.com",
      "pypi.org",
      "files.pythonhosted.org",
      "*.githubusercontent.com",
      "github.com",
      "api.github.com",
      "*.docker.io",
      "ghcr.io",
      "dl.polyhaven.org",
      "api.anthropic.com",
      "cdn.playwright.dev"
    ]
  }
}
