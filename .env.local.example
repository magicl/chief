###############################
#[backend]
###############################
# Copy to `.env.local` (gitignored). Group headers are required so env.split
# can bake these vars into `.output/env.compose.backend` for Docker Compose.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LOCAL_OPENAI_API_KEY=

# Fernet master key for encrypted credentials (apps.keys). Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Optional in dev (DEBUG=True) — uses settingsbase dev default when unset.
CREDENTIALS_KEY=

# Host `.local/agents` and `.local/keys` are mounted into compose at these paths.
# Create the dirs on the host (gitignored); use them for YAML configs / key files.
CHIEF_AGENTS_DIR=/mnt/local/agents
CHIEF_KEYS_DIR=/mnt/local/keys
