###############################
#[backend]
###############################
# Copy to `.env.local` (gitignored). Group headers are required so env.split
# can bake these vars into `.output/env.compose.backend` for Docker Compose.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LOCAL_OPENAI_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Compose sets CHIEF_LOCAL_DIR=/mnt/local on backend, worker, and Beat; only
# Beat scheduling and worker task execution drive reconciliation.

# Fernet master key for encrypted credentials (apps.keys). Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Optional in dev (DEBUG=True) — uses settingsbase dev default when unset.
CREDENTIALS_KEY=
