{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": false,
    "skipLibCheck": true,
    "types": ["vitest/globals", "node"]
  },
  "include": ["*.js", "*.mjs", "*.d.ts"],
  "exclude": ["node_modules", "codemirror", "rich-content"]
}
