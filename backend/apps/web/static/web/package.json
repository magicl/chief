{
  "name": "chief-web-static",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm run build:editor && pnpm run build:rich-content",
    "build:editor": "esbuild agent_config_editor.js --bundle --format=esm --outfile=codemirror/agent_config_editor.bundle.js --minify",
    "build:rich-content": "node build_rich_content.mjs",
    "lint": "eslint . --fix",
    "setup:browser": "playwright install --with-deps chromium",
    "test": "pnpm run test:unit && pnpm run test:browser",
    "test:browser": "vitest run --config vitest.browser.config.js",
    "test:unit": "vitest run --config vitest.config.js"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.5",
    "@vscode/markdown-it-katex": "^1.1.2",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.12",
    "esbuild": "^0.28.1",
    "katex": "0.16.47",
    "markdown-it": "^14.3.0",
    "mermaid": "^11.16.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.1.1",
    "@vitest/browser-playwright": "^4.1.10",
    "eslint": "^9.39.4",
    "globals": "^16.0.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "packageManager": "pnpm@10.4.1"
}
