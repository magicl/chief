FROM python:3.13-slim@sha256:6771159cd4fa5d9bba1258caf0b82e6b73458c694d178ad97c5e925c2d0e1a91

ENV LANG=C.UTF-8
ENV TZ=UTC
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*
RUN groupadd --system app \
    && useradd --system --gid app --home-dir /app app
COPY --from=ghcr.io/astral-sh/uv:0.11.29@sha256:eb2843a1e56fd9e30c7276ce1a52cba86e64c7b385f5e3279a0e08e02dd058fc /uv /usr/local/bin/uv

# Install only the backend's standalone locked runtime environment.
WORKDIR /app
COPY ./backend/pyproject.toml /app/pyproject.toml
COPY ./backend/uv.lock /app/uv.lock
RUN uv export --frozen --package chief-backend-env --output-file requirements.lock.txt \
    && uv pip install --system --require-hashes -r requirements.lock.txt --no-cache \
    && rm -f requirements.lock.txt /usr/local/bin/uv

COPY --chown=app:app ./olib /olib
COPY --chown=app:app ./backend /app

USER app

EXPOSE 8000

CMD ["./entrypoint.sh"]
